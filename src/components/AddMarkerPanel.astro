---
import { icon } from "../scripts/icons.js";
---
<section class="panel">
	<h2><Fragment set:html={icon("plus")} />Add new marker</h2>
	<div class="row">
		<div style="flex: 1; min-width: 220px;">
			<input id="newName" type="text" placeholder="marker_name" />
		</div>
		<button id="addBtn"><Fragment set:html={icon("plus")} /><span>Create</span></button>
	</div>
</section>

